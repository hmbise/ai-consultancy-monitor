# Database - Neon (Serverless PostgreSQL)
DATABASE_URL=postgresql://username:password@neon-host.neon.tech/dbname?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (for caching and Celery broker)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# AI/LLM - Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-70b-versatile  # or mixtral-8x7b-32768, gemma-7b-it

# Data Sources
NEWS_API_KEY=...
CRUNCHBASE_API_KEY=...
GLASSDOOR_API_KEY=...

# App Config
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Feature Flags
ENABLE_EMAIL_ENRICHMENT=false
ENABLE_LINKEDIN_OUTREACH=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text
